# Virtualenv / Python
.venv/
__pycache__/
*.pyc
.pytest_cache/

# Generated data, copyrighted source video, and face crops — never committed.
# NOTE: `data/*` (not `data/`) so the llm_cache negation below can take effect —
# git cannot re-include a path whose parent directory is excluded.
data/*

# ...except the LLM response cache (Milestone 3). Committing it means pytest and
# eval_story.py replay Gemma's answers offline, with no API key, on a fresh
# clone — preserving the repo's reproducibility guarantee.
!data/llm_cache/

# ...and except the hand-labeled grouping ground truth. It is the only input to
# eval_labeled, so committing it is what lets the Milestone 1 accuracy numbers be
# reproduced on a fresh clone instead of resting on a local-only file.
!data/ground_truth.csv

# Generated reports (regenerated by the pipeline)
reports/

# Model cache (downloaded on first run)
~/.insightface/

# Secrets: OPENROUTER_API_KEY for Milestone 3 narration (never commit)
.env

# OS
.DS_Store
